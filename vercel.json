{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run build"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "startCommand": "npm start"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}